# ===== LLM 設定 =====
# LLM 提供者：openai | mock | local
LLM_PROVIDER=mock

# OpenAI 設定（當 LLM_PROVIDER=openai 時需要）
# OPENAI_API_KEY 會從環境變數讀取（例如 ~/.bashrc）
OPENAI_MODEL=gpt-4o-mini

# 本地模型路徑（當 LLM_PROVIDER=local 時使用）
LLM_MODEL_PATH=/mnt/c/ai_models/llm/qwen2-7b-instruct

# ===== Embedding 設定 =====
USE_MOCK_VECTOR_STORE=true
EMBEDDING_MODEL=text-embedding-3-small
EMBED_MODEL_PATH=/mnt/c/ai_models/embeddings/text-embedding-model

# ===== 圖像生成設定 =====
USE_MOCK_IMAGE_CLIENT=true
SD_MODEL_PATH=/mnt/c/ai_models/stable-diffusion/sd1-5

# ===== 資料庫設定 =====
DATABASE_URL=sqlite+aiosqlite:///./app.db
USE_IN_MEMORY_STORAGE=true

# ===== 外部 API =====
BRAVE_API_KEY=your_brave_key_here

# ===== Cache 路徑 =====
HF_HOME=/mnt/c/ai_cache/huggingface
TRANSFORMERS_CACHE=/mnt/c/ai_cache/huggingface
TORCH_HOME=/mnt/c/ai_cache/torch
XDG_CACHE_HOME=/mnt/c/ai_cache
